<Window x:Class="EonsLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EonsLauncher"
        mc:Ignorable="d"
        Title="Eons Launcher"
        Width="900" Height="560"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.7"/>
    </Window.Effect>

    <Border CornerRadius="8" ClipToBounds="True">
        <Grid>
            <!-- Fond dégradé -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#080B12" Offset="0"/>
                        <GradientStop Color="#0E1420" Offset="0.5"/>
                        <GradientStop Color="#0A0E18" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Image Margin="0,8,-10,0" Source="/Resources/background.jpg" Stretch="Fill"/>
            </Border>

            <!-- Effet lumière dorée en haut -->
            <Border VerticalAlignment="Top" Height="200">
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.5,0" Center="0.5,0" RadiusX="0.7" RadiusY="0.5">
                        <GradientStop Color="#20C8A84B" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="110"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ===== BARRE DE TITRE ===== -->
                <Border Grid.Row="0" Background="#0D111A" MouseDown="TitleBar_MouseDown">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚔" FontSize="14" Foreground="{StaticResource BrushGold}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="EONS LAUNCHER" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource BrushGold}" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text=" — World of Warcraft 3.3.5a" FontSize="10"
                                       Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center"
                                       Margin="4,0,0,0" FontFamily="Segoe UI"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="32" Height="28" Click="MinimizeBtn_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="Transparent">
                                            <TextBlock Text="─" FontSize="14" HorizontalAlignment="Center"
                                                       VerticalAlignment="Bottom" Margin="0,0,0,4"
                                                       Foreground="{StaticResource BrushTextMuted}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#20FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Width="32" Height="28" Click="CloseBtn_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="Transparent">
                                            <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource BrushTextMuted}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#C0F44336"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== EN-TÊTE LOGO + STATUT SERVEUR ===== -->
                <Grid Grid.Row="1" Margin="24,12,24,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="32" FontWeight="Bold" FontFamily="Palatino Linotype">
                            <Run Foreground="{StaticResource BrushGold}" Text="EONS"/>
                            <Run Foreground="{StaticResource BrushText}" Text=" WORLD"/>
                        </TextBlock>
                        <TextBlock Text="Serveur privé Wrath of the Lich King" FontSize="12"
                                   Foreground="{StaticResource BrushTextMuted}" Margin="2,2,0,0"
                                   FontFamily="Segoe UI"/>
                        <Rectangle Height="1" Fill="{StaticResource BrushGold}" Opacity="0.3"
                                   Margin="0,6,0,0" HorizontalAlignment="Left" Width="200"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="6" Padding="16,10"
                            Background="#0D1A2A" BorderThickness="1"
                            BorderBrush="{StaticResource BrushBorder}" VerticalAlignment="Center">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource BrushRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource BrushGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"
                                           Text="{Binding ServerStatus}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsServerOnline}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource BrushGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="{Binding OnlinePlayers}" FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center" Margin="0,3,0,0" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== CONTENU PRINCIPAL ===== -->
                <Grid Grid.Row="2" Margin="24,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- ACTUALITÉS -->
                    <Border Grid.Column="0" CornerRadius="6" Background="#080C14"
                            BorderThickness="1" BorderBrush="{StaticResource BrushBorder}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#0D111A" CornerRadius="6,6,0,0"
                                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrushBorder}">
                                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                    <TextBlock Text="📜" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="ACTUALITÉS" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource BrushGold}"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding News}" Margin="0,4,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="8,4" Padding="12,10" CornerRadius="4"
                                                    Background="#0D1520" BorderThickness="1" BorderBrush="#1A2535">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <Border CornerRadius="2" Padding="5,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#1A3A5A"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="event">
                                                                            <Setter Property="Background" Value="#2A1A4A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="update">
                                                                            <Setter Property="Background" Value="#1A3A1A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="warning">
                                                                            <Setter Property="Background" Value="#3A2A0A"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="9" FontWeight="Bold" FontFamily="Segoe UI">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="INFO"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource BrushBlueLight}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type}" Value="event">
                                                                                <Setter Property="Text" Value="ÉVÉNEMENT"/>
                                                                                <Setter Property="Foreground" Value="#B060FF"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Type}" Value="update">
                                                                                <Setter Property="Text" Value="MISE À JOUR"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource BrushGreen}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Type}" Value="warning">
                                                                                <Setter Property="Text" Value="ATTENTION"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource BrushOrange}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding Date}" FontSize="10"
                                                                   Foreground="{StaticResource BrushTextMuted}"
                                                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold"
                                                               Foreground="{StaticResource BrushText}"
                                                               FontFamily="Segoe UI" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Content}" FontSize="11"
                                                               Foreground="{StaticResource BrushTextMuted}"
                                                               FontFamily="Segoe UI" TextWrapping="Wrap" LineHeight="16"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- PANNEAU LATÉRAL -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" CornerRadius="6" Background="#080C14"
                                BorderThickness="1" BorderBrush="{StaticResource BrushBorder}" Padding="12">
                            <StackPanel>
                                <TextBlock Text="📁 DOSSIER CLIENT" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushGold}"
                                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border CornerRadius="3" Background="#0D111A"
                                            BorderThickness="1" BorderBrush="{StaticResource BrushBorder}" Padding="6,4">
                                        <TextBlock Text="{Binding ClientPath}" FontSize="10"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   TextTrimming="CharacterEllipsis" FontFamily="Consolas"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="..." Margin="4,0,0,0"
                                            Width="28" Height="24" Padding="0"
                                            Style="{StaticResource ButtonBlue}"
                                            Click="BrowsePath_Click" ToolTip="Changer le dossier"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" CornerRadius="6" Background="#080C14"
                                BorderThickness="1" BorderBrush="{StaticResource BrushBorder}" Margin="0,8,0,8" Grid.RowSpan="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#0D111A" CornerRadius="6,6,0,0"
                                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrushBorder}">
                                    <TextBlock Text="⚙ JOURNAL" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushGold}"
                                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="12,0"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Logs}" Margin="8,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="9"
                                                           Foreground="{StaticResource BrushTextMuted}"
                                                           FontFamily="Consolas" TextWrapping="Wrap" Margin="0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ===== BARRE DU BAS ===== -->
                <Border Grid.Row="3" Background="#0A0D16"
                        BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushBorder}" Padding="24,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10"
                              Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar Style="{StaticResource GoldProgressBar}"
                                         Value="{Binding GlobalProgress}" Maximum="100"/>
                            <TextBlock Grid.Column="1" Text="{Binding ProgressText}" FontSize="10"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Segoe UI"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="Bold"
                                           Foreground="{StaticResource BrushText}" FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding SubStatusText}" FontSize="10"
                                           Foreground="{StaticResource BrushTextMuted}" FontFamily="Segoe UI"
                                           Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="🌐 Site Web" Padding="12,8"
                                        Style="{StaticResource ButtonBlue}" Margin="0,0,8,0"
                                        Click="Website_Click"/>
                                <Button Content="✦ S'inscrire" Padding="12,8"
                                        Style="{StaticResource ButtonBlue}" Margin="0,0,8,0"
                                        Click="Register_Click"/>
                                <Button Content="↻ Vérifier" Padding="12,8"
                                        Style="{StaticResource ButtonBlue}" Margin="0,0,8,0"
                                        Click="Refresh_Click"
                                        IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBoolConverter}}"/>
                                <Button Content="✕ Annuler" Padding="12,8"
                                        Style="{StaticResource ButtonBlue}" Margin="0,0,8,0"
                                        Click="Cancel_Click"
                                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="⬇ Mettre à jour" Padding="16,8"
                                        Style="{StaticResource ButtonGold}" Margin="0,0,8,0"
                                        IsEnabled="{Binding CanUpdate}"
                                        Click="Update_Click"
                                        Visibility="{Binding CanUpdate, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="⚔ JOUER" Padding="24,8"
                                        Style="{StaticResource ButtonGold}"
                                        IsEnabled="{Binding CanPlay}"
                                        Click="Play_Click" FontSize="15"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
